# Sagittarius Environment Configuration
# Copy this file to .env and adjust values as needed.

# JMAP server URL (used by Vite dev server proxy)
# Default: http://localhost:8080
VITE_JMAP_SERVER=http://localhost:8080

# Optional login alias domain. When set, Sagittarius accepts bare usernames
# like "remcov" and also retries "remcov@wellintime.com" plus
# internal usernames such as "remcov-wellintime" when needed.
# VITE_LOGIN_EMAIL_DOMAIN=wellintime.com
