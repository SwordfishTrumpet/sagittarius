{
  "name": "sagittarius",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A high-performance, server-agnostic JMAP web client with iCloud Mail aesthetics",
  "author": "SwordfishTrumpet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SwordfishTrumpet/sagittarius.git"
  },
  "homepage": "https://github.com/SwordfishTrumpet/sagittarius",
  "bugs": {
    "url": "https://github.com/SwordfishTrumpet/sagittarius/issues"
  },
  "keywords": [
    "jmap",
    "email",
    "webmail",
    "mail-client",
    "rfc8620",
    "rfc8621",
    "react",
    "typescript",
    "tailwindcss"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node server.js",
    "deploy": "./deploy.sh",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:fast": "vitest run --reporter=dot",
    "test:ci": "CI=true vitest run --reporter=dot",
    "test:changed": "vitest run --changed",
    "test:staged": "vitest run --related $(git diff --name-only --staged | grep -E '\\.(ts|tsx)$' | tr '\\n' ' ')",
    "test:file": "vitest run --reporter=verbose",
    "test:headless": "vitest run --maxThreads=8",
    "test:sequential": "vitest run --singleThread=true",
    "test:debug": "vitest run --reporter=verbose --singleThread=true",
    "benchmark": "tsx src/test/performance/index.ts",
    "benchmark:quick": "tsx src/test/performance/index.ts --quick"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tiptap/extension-link": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/extension-underline": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "compression": "^1.8.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.3",
    "dompurify": "^3.4.8",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "http-proxy": "^1.18.1",
    "http-proxy-middleware": "^4.0.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dnd-touch-backend": "^16.0.1",
    "react-dom": "^19.2.7",
    "react-virtuoso": "^4.18.7",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-axe": "^0.1.0"
  }
}
